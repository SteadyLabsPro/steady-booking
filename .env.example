# Copy to .env.local and fill in. Never commit real keys.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend ---
RESEND_API_KEY=
# From address for emails, e.g. "The Tide House <bookings@thetidehouse.co.uk>".
# For testing before domain verification, use "onboarding@resend.dev".
RESEND_FROM=

# --- Admin Lite ---
# Shared password for the /admin dashboard. Set locally and in the host env.
ADMIN_PASSWORD=
